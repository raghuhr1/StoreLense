# ─── StoreLense local environment ────────────────────────────────────────────
# Copy to .env and adjust values before running docker-compose up

# PostgreSQL
POSTGRES_PASSWORD=postgres
DB_PASSWORD=changeme
DB_USERNAME=storelense_app
DB_NAME=storelense

# Redis
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP=kafka:9092

# JWT (min 32 chars)
JWT_SECRET=storelense-dev-secret-key-minimum-32-chars

# Service URLs (used by services that call each other directly)
PRODUCT_SERVICE_URL=http://product-service:8083
STORE_SERVICE_URL=http://store-service:8082

# ERP integration (optional for local dev)
ERP_BASE_URL=http://erp-mock:9000
ERP_API_KEY=dev-key
ERP_API_VERSION=v1
ERP_PUSH_SOH_ENABLED=false

# Frontend gateway URL
INTERNAL_API_URL=http://nginx-gateway:8080
