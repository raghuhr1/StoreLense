# ─── StoreLense Observability stack ──────────────────────────────────────────
# Copy to .env.observability and fill in values matching your .env

# ── PostgreSQL (must match values in your main .env) ─────────────────────────
DB_USERNAME=storelense_app
DB_PASSWORD=changeme
DB_NAME=storelense

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=StoreLense@Obs1

# ── Email alerts (optional — set GRAFANA_SMTP_ENABLED=true to enable) ─────────
GRAFANA_SMTP_ENABLED=false
GRAFANA_SMTP_HOST=smtp.gmail.com:587
GRAFANA_SMTP_USER=your-email@gmail.com
GRAFANA_SMTP_PASSWORD=your-app-password
GRAFANA_SMTP_FROM=alerts@storelense.in
